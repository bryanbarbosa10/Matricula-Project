<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AMPS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AMPS"
    FlyoutBehavior="Flyout">

    <!-- Main page -->
    <FlyoutItem Title="Dashboard">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate local:Dashboard}"
            Route="Dashboard" />
    </FlyoutItem>

    <!-- Profile management -->
    <FlyoutItem Title="Administración de Perfiles">
        <ShellContent
            Title="Administración de Perfiles"
            ContentTemplate="{DataTemplate local:ProfileManagement}"
            Route="ProfileManagement" />
    </FlyoutItem>

    <!-- Secuencial -->
    <FlyoutItem Title="Secuencial">
        <ShellContent
            Title="Secuencial"
            ContentTemplate="{DataTemplate local:Secuencial}"
            Route="Secuencial" />
    </FlyoutItem>

    <!-- Promedio -->
    <FlyoutItem Title="Promedio">
        <ShellContent
        Title="Promedio"
        ContentTemplate="{DataTemplate local:Promedio}"
        Route="Promedio" />
    </FlyoutItem>

    <!-- Matricula -->
    <FlyoutItem Title="Matricula">
        <ShellContent
            Title="Matricula"
            ContentTemplate="{DataTemplate local:Matricula}"
            Route="Matricula" />
    </FlyoutItem>

</Shell>