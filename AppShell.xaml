<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AMPS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AMPS"
    Shell.FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="20" BackgroundColor="#2196F3">
            <Label x:Name="LblEstudianteId" 
                   Text="Estudiante AMPS" 
                   HorizontalOptions="Center" 
                   FontAttributes="Bold" 
                   TextColor="White"/>
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <FlyoutItem Title="Matrícula" Icon="dotnet_bot.png">
        <ShellContent ContentTemplate="{DataTemplate local:Matricula}" />
    </FlyoutItem>

    <FlyoutItem Title="Promedio" Icon="dotnet_bot.png">
        <ShellContent ContentTemplate="{DataTemplate local:Promedio}" />
    </FlyoutItem>

    <FlyoutItem Title="Secuencial" Icon="dotnet_bot.png">
        <ShellContent ContentTemplate="{DataTemplate local:Secuencial}" />
    </FlyoutItem>

</Shell>