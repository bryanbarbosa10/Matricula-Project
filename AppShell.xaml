<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AMPS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AMPS"
    Shell.FlyoutBehavior="Flyout">

    <!-- TempHome/user create -->
    <FlyoutItem Title="Home">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </FlyoutItem>

    <!-- Secuencial -->
    <FlyoutItem Title="Secuencial">
        <ShellContent
            Title="Secuencial"
            ContentTemplate="{DataTemplate local:Secuencial}"
            Route="Secuencial" />
    </FlyoutItem>

    <!-- Matricula -->
    <FlyoutItem Title="Matricula">
        <ShellContent
            Title="Matricula"
            ContentTemplate="{DataTemplate local:Matricula}"
            Route="Matricula" />
    </FlyoutItem>

    <!-- Promedio -->
    <FlyoutItem Title="Promedio">
        <ShellContent
            Title="Promedio"
            ContentTemplate="{DataTemplate local:Promedio}"
            Route="Promedio" />
    </FlyoutItem>

</Shell>