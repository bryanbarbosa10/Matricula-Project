<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="AMPS.Promedio"
             Title="Calculadora de Promedio">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Promedio Acumulado" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource AmpsBlue}"/>

            <Frame BorderColor="{StaticResource AmpsBlue}" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Añadir Nueva Calificación" FontAttributes="Bold" />
                    <Entry x:Name="EntMateria" Placeholder="Nombre de Materia (ej. COMP2800)" />
                    <Entry x:Name="EntCreditos" Placeholder="Créditos" Keyboard="Numeric" />
                    <Picker x:Name="PickNota" Title="Selecciona tu Nota">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>A</x:String>
                                <x:String>B</x:String>
                                <x:String>C</x:String>
                                <x:String>D</x:String>
                                <x:String>F</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                    <Button Text="Calcular y Añadir" 
                            BackgroundColor="{StaticResource AmpsBlue}" 
                            Clicked="OnCalcularGPAClicked" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{StaticResource AmpsPink}" CornerRadius="10">
                <VerticalStackLayout>
                    <Label Text="Resultado Actual" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    <Label x:Name="LblResultadoGPA" Text="0.00"/>
                </VerticalStackLayout>
            </Frame>

            <Grid Margin="0,10,0,0" BackgroundColor="{StaticResource AmpsBlue}" Padding="15">
                <Label Text="GPA TOTAL CARRERA" TextColor="White" FontAttributes="Bold" HorizontalOptions="Start" VerticalOptions="Center"/>
                <Label x:Name="LblGpaTotal" Text="0.00" />
             </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>