<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AMPS.Matricula"
             Title="Mis Matrículas">



    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Matrículas Registradas" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Button Text="+" 
            FontSize="30" 
            WidthRequest="60" 
            HeightRequest="60" 
            CornerRadius="30" 
            BackgroundColor="#C8E6C9" 
            TextColor="Black" 
            HorizontalOptions="Center"
            Clicked="OnAddMatriculaClicked"/>   

        <Label Text="Añadir Matrícula" HorizontalOptions="Center"/>

        <Frame BackgroundColor="#F8BBD0" Padding="15" CornerRadius="5">
            <Label Text="Semestre 1" HorizontalOptions="Center"/>
        </Frame>
        
        <Frame BackgroundColor="#BBDEFB" Padding="15" CornerRadius="5">
            <Label Text="Semestre 2" HorizontalOptions="Center"/>
        </Frame>
    </VerticalStackLayout>
</ContentPage>