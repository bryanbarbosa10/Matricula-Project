<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AMPS.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label 
            Text="AMPS"
            FontSize="32"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

            <Entry
            x:Name="StudentID"
            Placeholder="StudentID"
            BackgroundColor="White"
            TextColor="Black" />

            <Entry
            x:Name="Password"
            Placeholder="Password"
            IsPassword="True"
            BackgroundColor="White"
            TextColor="Black" />

            <Button
            Text="Login"
            BackgroundColor="#2196F3"
            TextColor="White"
            CornerRadius="8"
            Clicked="OnLoginClicked"/>

            <Button
            Text="Sign Up"
            BackgroundColor="Gray"
            TextColor="White"
            CornerRadius="8"
            Clicked="OnSignUpClicked"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
