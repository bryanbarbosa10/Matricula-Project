
    
    
    <ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AMPS.MainPage">

    <ScrollView>
        <VerticalStackLayout
            
            Padding="30,40"
            Spacing="20">

            <!-- App title -->
            <Label
                Text="AMPS"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <!-- subtitle -->
            <Label
                Text="Create your student profile"
                FontSize="18"
                HorizontalOptions="Center" />

            
            
            <!-- Fields -->
            <Entry
                x:Name="NameEntry"
                Placeholder="Name"
                MaxLength="30"
                BackgroundColor="White"
                TextColor="Black" />

            <Entry
                x:Name="StudentIdEntry"
                Placeholder="Student ID"
                MaxLength="25"
                BackgroundColor="White"
                TextColor="Black" />

            
            <Entry
                x:Name="EmailEntry"
                Placeholder="University Email (Optional)"
                Keyboard="Email"
                BackgroundColor="White"
                TextColor="Black" />

            <!-- SaveButton -->
            <Button
                Text="Save Profile"
                BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="8"
                Clicked="OnSaveProfileClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>